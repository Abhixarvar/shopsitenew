<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aarchi Fashion</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --sky:#d6eeff;
  --sky2:#b8dfff;
  --sky3:#e8f5ff;
  --navy:#1a3a5c;
  --navy2:#0d2440;
  --accent:#1a73e8;
  --gold:#c8a96e;
  --gold2:#e8c98e;
  --white:#ffffff;
  --text:#1a1a2e;
  --text2:#4a5568;
  --border:#c5ddf5;
  --card:#f0f8ff;
  --red:#c0392b;
}

body{font-family:'Poppins',sans-serif;background:var(--sky3);color:var(--text);min-height:100vh}

/* ── TOP BAR ── */
.topbar{background:var(--navy2);color:#a8c8f0;font-size:11px;padding:6px 24px;display:flex;justify-content:space-between;align-items:center}
.topbar a{color:#a8c8f0;text-decoration:none;margin-left:16px;transition:color .2s}
.topbar a:hover{color:#fff}

/* ── HEADER ── */
header{background:var(--white);border-bottom:3px solid var(--gold);padding:0;position:sticky;top:0;z-index:900;box-shadow:0 2px 20px rgba(26,58,92,.12)}
.header-inner{max-width:1300px;margin:0 auto;padding:18px 24px;display:flex;align-items:center;gap:20px}

.logo{display:flex;flex-direction:column;cursor:pointer;min-width:200px}
.logo-main{font-family:'Playfair Display',serif;font-size:28px;font-weight:900;color:var(--navy);letter-spacing:1px;line-height:1}
.logo-main span{color:var(--accent)}
.logo-sub{font-size:9px;color:var(--gold);letter-spacing:3px;text-transform:uppercase;margin-top:3px}

.search-bar{flex:1;max-width:520px;display:flex;border:2px solid var(--border);border-radius:2px;overflow:hidden;transition:border .2s}
.search-bar:focus-within{border-color:var(--accent)}
.search-bar input{flex:1;padding:10px 16px;border:none;outline:none;font-family:'Poppins',sans-serif;font-size:14px;background:var(--sky3)}
.search-bar button{background:var(--navy);color:#fff;border:none;padding:10px 20px;cursor:pointer;font-size:15px;transition:background .2s}
.search-bar button:hover{background:var(--accent)}

.hdr-right{display:flex;gap:10px;align-items:center;margin-left:auto}
.hdr-btn{background:none;border:2px solid var(--navy);color:var(--navy);padding:8px 18px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;cursor:pointer;letter-spacing:.5px;transition:all .2s;display:flex;align-items:center;gap:6px}
.hdr-btn:hover{background:var(--navy);color:#fff}
.hdr-btn.cart{background:var(--navy);color:#fff}
.hdr-btn.cart:hover{background:var(--navy2)}
.cart-ct{background:var(--gold);color:var(--navy);border-radius:50%;width:18px;height:18px;font-size:10px;font-weight:800;display:inline-flex;align-items:center;justify-content:center}

/* ── NAV ── */
nav{background:var(--sky);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1300px;margin:0 auto;padding:0 24px;display:flex;overflow-x:auto}
.nav-inner a{color:var(--navy);text-decoration:none;padding:10px 18px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;white-space:nowrap;border-bottom:3px solid transparent;transition:all .2s}
.nav-inner a:hover{color:var(--accent);border-bottom-color:var(--gold)}

/* ── HERO ── */
.hero{position:relative;height:520px;overflow:hidden;display:flex;align-items:center}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center top;filter:brightness(.55)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(13,36,64,.85) 0%,rgba(26,58,92,.4) 60%,transparent 100%)}
.hero-content{position:relative;z-index:2;padding:0 80px;max-width:700px}
.hero-tag{display:inline-block;background:var(--gold);color:var(--navy);font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;padding:6px 16px;margin-bottom:20px}
.hero-content h1{font-family:'Playfair Display',serif;font-size:62px;font-weight:900;color:#fff;line-height:1;margin-bottom:16px;text-transform:uppercase}
.hero-content h1 span{color:var(--gold2);display:block}
.hero-content p{color:#b8d4f0;font-size:15px;margin-bottom:28px;line-height:1.6}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.btn-hero{padding:14px 32px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border:none;transition:all .25s}
.btn-hero.primary{background:var(--gold);color:var(--navy)}
.btn-hero.primary:hover{background:var(--gold2)}
.btn-hero.outline{background:transparent;color:#fff;border:2px solid #fff}
.btn-hero.outline:hover{background:#fff;color:var(--navy)}

/* ── HERO THUMBS (right side) ── */
.hero-thumbs{position:absolute;right:40px;top:50%;transform:translateY(-50%);z-index:3;display:flex;flex-direction:column;gap:10px}
.hero-thumb{width:70px;height:90px;border:3px solid rgba(255,255,255,.3);overflow:hidden;cursor:pointer;transition:all .3s}
.hero-thumb.active,.hero-thumb:hover{border-color:var(--gold);transform:scale(1.08)}
.hero-thumb img{width:100%;height:100%;object-fit:cover}

/* ── ANNOUNCE STRIP ── */
.announce{background:var(--navy);color:var(--gold2);text-align:center;padding:10px;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase}

/* ── SECTION ── */
.section{max-width:1300px;margin:0 auto;padding:60px 24px}
.sec-header{text-align:center;margin-bottom:48px}
.sec-tag{display:inline-block;background:var(--sky2);color:var(--navy);font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;padding:5px 14px;margin-bottom:12px}
.sec-title{font-family:'Playfair Display',serif;font-size:36px;font-weight:900;color:var(--navy);text-transform:uppercase;letter-spacing:2px}
.sec-line{width:60px;height:3px;background:var(--gold);margin:14px auto 0}

/* ── CATEGORIES ── */
.cats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:16px}
.cat-card{background:var(--white);border:1.5px solid var(--border);padding:24px 12px;text-align:center;cursor:pointer;transition:all .25s}
.cat-card:hover{border-color:var(--navy);transform:translateY(-4px);box-shadow:0 8px 24px rgba(26,58,92,.12)}
.cat-icon{font-size:36px;display:block;margin-bottom:10px}
.cat-name{font-size:11px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:1px}

/* ── PRODUCTS ── */
.products-wrap{background:var(--white);border:1px solid var(--border)}
.products-header{display:flex;align-items:center;justify-content:space-between;padding:20px 28px;border-bottom:2px solid var(--sky)}
.products-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--navy)}
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:0}

.prod-card{border-right:1px solid var(--border);border-bottom:1px solid var(--border);cursor:pointer;transition:all .2s;background:#fff;position:relative}
.prod-card:hover{background:var(--sky3);z-index:2;box-shadow:0 0 0 2px var(--navy)}
.prod-badge{position:absolute;top:0;left:0;background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:4px 10px;letter-spacing:1px;z-index:2}
.prod-badge.new-badge{background:var(--navy)}
.prod-img{width:100%;aspect-ratio:3/4;overflow:hidden;background:var(--sky);display:flex;align-items:center;justify-content:center;font-size:80px}
.prod-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.prod-card:hover .prod-img img{transform:scale(1.05)}
.prod-info{padding:14px 16px}
.prod-name{font-size:13px;font-weight:600;color:var(--text);margin-bottom:8px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.prod-price{display:flex;align-items:baseline;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.price-now{font-size:18px;font-weight:800;color:var(--navy)}
.price-old{font-size:12px;color:#999;text-decoration:line-through}
.price-off{font-size:11px;font-weight:700;color:#27ae60}
.prod-btns{display:flex;gap:8px}
.btn-cart{flex:1;background:var(--navy);color:#fff;border:none;padding:9px;font-family:'Poppins',sans-serif;font-size:12px;font-weight:600;letter-spacing:.5px;cursor:pointer;transition:background .2s}
.btn-cart:hover{background:var(--accent)}
.btn-wa{background:var(--sky);color:var(--navy);border:1.5px solid var(--border);padding:9px 12px;font-size:14px;cursor:pointer;transition:all .2s}
.btn-wa:hover{background:#25d366;color:#fff;border-color:#25d366}

/* ── PROMO BANNER ── */
.promo-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:60px}
.promo-card{position:relative;height:300px;overflow:hidden;cursor:pointer}
.promo-card img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.promo-card:hover img{transform:scale(1.05)}
.promo-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,36,64,.85) 0%,transparent 60%)}
.promo-text{position:absolute;bottom:28px;left:28px;color:#fff}
.promo-text h3{font-family:'Playfair Display',serif;font-size:26px;font-weight:900;text-transform:uppercase;letter-spacing:1px}
.promo-text p{font-size:12px;color:var(--gold2);letter-spacing:2px;text-transform:uppercase;margin-top:4px}
.promo-btn{display:inline-block;margin-top:12px;background:var(--gold);color:var(--navy);padding:8px 20px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border:none;font-family:'Poppins',sans-serif;transition:background .2s}
.promo-btn:hover{background:var(--gold2)}

/* ── FOOTER ── */
footer{background:var(--navy2);color:#a8c8f0;padding:60px 24px 24px}
.footer-inner{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;margin-bottom:40px}
.footer-brand .logo-main{color:#fff;font-size:24px}
.footer-brand .logo-main span{color:var(--gold)}
.footer-brand p{font-size:13px;color:#7097c0;margin-top:12px;line-height:1.7}
.footer-col h4{color:var(--gold2);font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:18px}
.footer-col a{display:block;font-size:13px;color:#7097c0;text-decoration:none;margin-bottom:10px;transition:color .2s}
.footer-col a:hover{color:#fff}
.footer-col p{font-size:13px;color:#7097c0;margin-bottom:10px;line-height:1.6}
.footer-bottom{max-width:1300px;margin:0 auto;border-top:1px solid rgba(255,255,255,.08);padding-top:24px;text-align:center;font-size:12px;color:#4a6580}

/* ── CART SIDEBAR ── */
.cart-sidebar{position:fixed;right:-440px;top:0;width:420px;height:100vh;background:#fff;z-index:1500;box-shadow:-4px 0 30px rgba(0,0,0,.15);transition:right .3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column}
.cart-sidebar.open{right:0}
.cart-hdr{background:var(--navy);color:#fff;padding:18px 22px;display:flex;align-items:center;justify-content:space-between}
.cart-hdr h3{font-family:'Playfair Display',serif;font-size:20px;font-weight:700}
.cart-close{background:rgba(255,255,255,.15);border:none;color:#fff;width:32px;height:32px;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center}
.cart-body{flex:1;overflow-y:auto;padding:16px}
.cart-item{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid var(--border)}
.ci-img{width:72px;height:92px;overflow:hidden;flex-shrink:0;background:var(--sky)}
.ci-img img,.ci-img-emoji{width:100%;height:100%;object-fit:cover;display:flex;align-items:center;justify-content:center;font-size:38px}
.ci-info{flex:1}
.ci-name{font-size:13px;font-weight:600;margin-bottom:6px;line-height:1.4}
.ci-price{font-size:15px;font-weight:800;color:var(--navy)}
.qty-row{display:flex;align-items:center;gap:10px;margin-top:8px}
.qty-btn{width:28px;height:28px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.qty-btn:hover{border-color:var(--navy);color:var(--navy)}
.qty-n{font-size:14px;font-weight:700;min-width:22px;text-align:center}
.ci-del{background:none;border:none;color:var(--red);font-size:11px;cursor:pointer;margin-top:6px;font-family:'Poppins',sans-serif}
.cart-empty{text-align:center;padding:60px 20px;color:#999}
.cart-footer-area{padding:16px 22px;border-top:1.5px solid var(--border)}
.cart-total-row{display:flex;justify-content:space-between;font-size:16px;font-weight:800;margin-bottom:14px;color:var(--navy)}
.btn-checkout{width:100%;background:var(--navy);color:#fff;border:none;padding:14px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:background .2s}
.btn-checkout:hover{background:var(--accent)}

/* ── MODALS ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:2000;align-items:center;justify-content:center}
.modal-overlay.active{display:flex}
.modal{background:#fff;width:90%;max-width:480px;max-height:90vh;overflow-y:auto;animation:min .3s cubic-bezier(.34,1.56,.64,1)}
@keyframes min{from{transform:scale(.85);opacity:0}to{transform:scale(1);opacity:1}}
.modal-hdr{background:var(--navy);color:#fff;padding:20px 26px;display:flex;align-items:center;justify-content:space-between}
.modal-hdr h3{font-family:'Playfair Display',serif;font-size:20px;font-weight:700}
.modal-close{background:rgba(255,255,255,.15);border:none;color:#fff;width:30px;height:30px;cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center}
.modal-body{padding:26px}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--navy);margin-bottom:6px}
.form-group input,.form-group select,.form-group textarea{width:100%;border:1.5px solid var(--border);padding:10px 14px;font-family:'Poppins',sans-serif;font-size:14px;outline:none;transition:border .2s;background:var(--sky3)}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--navy)}
.btn-primary{width:100%;background:var(--navy);color:#fff;border:none;padding:13px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:background .2s;margin-top:6px}
.btn-primary:hover{background:var(--accent)}
.btn-google{width:100%;background:#fff;color:#333;border:1.5px solid #dadce0;padding:11px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:background .2s;margin-bottom:14px}
.btn-google:hover{background:#f5f5f5}
.divider{text-align:center;font-size:12px;color:#999;margin:12px 0;position:relative}
.divider::before,.divider::after{content:'';position:absolute;top:50%;width:40%;height:1px;background:var(--border)}
.divider::before{left:0}.divider::after{right:0}
.admin-badge{background:var(--gold);color:var(--navy);font-size:9px;font-weight:800;padding:2px 7px;letter-spacing:1px}

/* ── ADMIN IMAGE UPLOAD ── */
.img-upload-area{border:2px dashed var(--border);padding:20px;text-align:center;cursor:pointer;transition:border .2s;background:var(--sky3);margin-bottom:12px}
.img-upload-area:hover{border-color:var(--navy)}
.img-upload-area input{display:none}
.img-preview{width:100%;height:120px;object-fit:cover;margin-top:8px;display:none}

/* ── PRODUCT DETAIL ── */
.pd-img{width:100%;aspect-ratio:3/4;overflow:hidden;background:var(--sky);display:flex;align-items:center;justify-content:center;font-size:100px}
.pd-img img{width:100%;height:100%;object-fit:cover}
.pd-body{padding:24px}
.pd-name{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--navy);margin-bottom:10px}
.pd-price{font-size:28px;font-weight:900;color:var(--navy);margin-bottom:14px}
.pd-desc{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:20px}
.pd-actions{display:flex;gap:12px}
.pd-actions .btn-cart{font-size:13px;padding:13px;letter-spacing:1px}
.pd-wa{background:#25d366;color:#fff;border:none;padding:13px 22px;font-family:'Poppins',sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;cursor:pointer;transition:background .2s}
.pd-wa:hover{background:#1da851}

/* ── SIDEBAR OVERLAY ── */
.sidebar-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1400}
.sidebar-ov.active{display:block}

/* ── TOAST ── */
.toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--navy);color:#fff;padding:13px 26px;font-size:14px;font-weight:500;z-index:9999;transition:transform .3s;letter-spacing:.5px}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.success{background:#27ae60}
.toast.wa{background:#25d366}

/* ── ADMIN PRODUCT ROW ── */
.adm-row{display:flex;align-items:center;gap:12px;padding:10px;border-bottom:1px solid var(--border);font-size:13px}
.adm-row span{flex:1}
.adm-del{background:#ffebee;color:var(--red);border:none;padding:5px 12px;cursor:pointer;font-size:12px;font-family:'Poppins',sans-serif}

/* ── USER AVATAR ── */
.uavatar{width:30px;height:30px;background:var(--gold);color:var(--navy);font-size:13px;font-weight:800;border-radius:50%;display:inline-flex;align-items:center;justify-content:center}

/* ── RESPONSIVE ── */
@media(max-width:768px){
  .hero{height:340px}
  .hero-content{padding:0 24px}
  .hero-content h1{font-size:36px}
  .hero-thumbs{display:none}
  .promo-grid{grid-template-columns:1fr}
  .header-inner{flex-wrap:wrap;gap:12px}
  .search-bar{order:3;width:100%;max-width:100%}
  .logo{min-width:150px}
  .logo-main{font-size:20px}
  .cart-sidebar{width:100%;right:-100%}
  .products-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
  .section{padding:40px 16px}
}

/* ── PATTERN STRIP ── */
.pattern-strip{height:8px;background:repeating-linear-gradient(90deg,var(--gold) 0,var(--gold) 10px,var(--navy) 10px,var(--navy) 20px,var(--sky2) 20px,var(--sky2) 30px,var(--navy) 30px,var(--navy) 40px)}
</style>
</head>
