<!-- HERO -->
<div class="hero" id="hero-section">
  <div class="hero-bg" id="hero-bg" style="background-image:url('data:image/png;base64,')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-tag">New Collection 2024</div>
