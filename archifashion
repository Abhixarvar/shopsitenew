// ============================================================
// PRODUCTS DATA
// ============================================================
let products = [
  { id:1, name:'Bridal Half-Half Silk Saree', category:'Saree', price:4999, mrp:8999, emoji:'👘', desc:'Stunning half-half design with heavy embroidery, perfect for weddings.', img:SAREE1 },
  { id:2, name:'Pink Banarasi Silk Saree', category:'Saree', price:3499, mrp:6999, emoji:'👘', desc:'Rich pink banarasi silk with golden zari border, ideal for festivals.', img:SAREE2 },
  { id:3, name:'Cream Tissue Silk Saree', category:'Saree', price:5999, mrp:10999, emoji:'👘', desc:'Elegant cream tissue silk with pink border, timeless & graceful.', img:SAREE3 },
  { id:4, name:'Kanjivaram Pure Silk Saree', category:'Saree', price:6999, mrp:12999, emoji:'👘', desc:'Authentic Kanjivaram with temple border. Heirloom quality.', img:'' },
  { id:5, name:'Designer Anarkali Suit', category:'Suit', price:2199, mrp:3999, emoji:'👗', desc:'Floor-length anarkali with intricate embroidery work.', img:'' },
  { id:6, name:'Salwar Kameez Palazzo Set', category:'Suit', price:1599, mrp:2999, emoji:'👗', desc:'Comfortable palazzo set with matching dupatta.', img:'' },
  { id:7, name:'Bridal Lehenga Choli — Red', category:'Lehenga', price:8999, mrp:16999, emoji:'🌸', desc:'Heavy embroidered bridal lehenga with blouse & dupatta.', img:'' },
  { id:8, name:'Net Embroidered Lehenga', category:'Lehenga', price:4499, mrp:7999, emoji:'🌸', desc:'Party-wear net lehenga with mirror work detailing.', img:'' },
  { id:9, name:'Chiffon Printed Dupatta', category:'Dupatta', price:499, mrp:999, emoji:'🧣', desc:'Light chiffon dupatta with floral prints.', img:'' },
  { id:10, name:'Designer Cotton Kurti', category:'Kurti', price:799, mrp:1499, emoji:'👔', desc:'Block-printed cotton kurti for casual & semi-formal wear.', img:'' },
  { id:11, name:'Sharara Set — Pink', category:'Sharara', price:2799, mrp:4999, emoji:'💃', desc:'Festive sharara with kurti and dupatta. Party-ready look.', img:'' },
  { id:12, name:'Floor-Length Party Gown', category:'Gown', price:3299, mrp:5999, emoji:'👑', desc:'Elegant floor-length gown for parties & sangeet.', img:'' },
];

// ============================================================
// RENDER PRODUCTS
// ============================================================
function renderProducts(list) {
  const grid = document.getElementById('products-grid');
  if (!list || list.length === 0) {
    grid.innerHTML = '<div style="text-align:center;padding:60px;color:#999;grid-column:1/-1;font-size:15px">No products found.</div>';
    return;
  }
  grid.innerHTML = list.map(p => {
    const disc = Math.round(((p.mrp - p.price)/p.mrp)*100);
    const imgHtml = p.img
      ? `<img src="${p.img}" alt="${p.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
        + `<span style="display:none;align-items:center;justify-content:center;width:100%;height:100%;font-size:80px">${p.emoji}</span>`
      : `<span>${p.emoji}</span>`;
    return `<div class="prod-card" onclick="openPD(${p.id})">
      ${disc>0?`<div class="prod-badge">${disc}% OFF</div>`:''}
      <div class="prod-img">${imgHtml}</div>
      <div class="prod-info">
        <div class="prod-name">${p.name}</div>
        <div class="prod-price">
          <span class="price-now">₹${p.price.toLocaleString('en-IN')}</span>
          <span class="price-old">₹${p.mrp.toLocaleString('en-IN')}</span>
          ${disc>0?`<span class="price-off">${disc}% off</span>`:''}
        </div>
        <div class="prod-btns">
          <button class="btn-cart" onclick="event.stopPropagation();addToCart(${p.id})">Add to Cart</button>
          <button class="btn-wa" onclick="event.stopPropagation();shareWA(${p.id})" title="WhatsApp">💬</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function filterByCategory(cat) {
  currentCategory = cat;
  const filtered = cat==='all' ? products : products.filter(p=>p.category===cat);
  document.getElementById('products-title').textContent = cat==='all' ? '✦ Featured Collection' : `✦ ${cat} Collection`;
  renderProducts(filtered);
  document.getElementById('products').scrollIntoView({behavior:'smooth'});
}

function filterProducts() {
  const q = document.getElementById('search-input').value.toLowerCase();
  const filtered = products.filter(p => p.name.toLowerCase().includes(q)||p.category.toLowerCase().includes(q)||p.desc.toLowerCase().includes(q));
  document.getElementById('products-title').textContent = `✦ Search: "${q}"`;
  renderProducts(filtered);
}

// ============================================================
// PRODUCT DETAIL
// ============================================================
function openPD(id) {
  const p = products.find(x=>x.id===id);
  if(!p) return;
  const disc = Math.round(((p.mrp-p.price)/p.mrp)*100);
  const imgHtml = p.img
    ? `<img src="${p.img}" alt="${p.name}" onerror="this.style.display='none'">`
    : `<span>${p.emoji}</span>`;
  document.getElementById('pd-modal-cat').textContent = p.category;
  document.getElementById('pd-content').innerHTML = `
    <div class="pd-img">${imgHtml}</div>
    <div class="pd-body">
      <div class="pd-name">${p.name}</div>
      <div class="pd-price">₹${p.price.toLocaleString('en-IN')}
        <span style="font-size:16px;color:#999;text-decoration:line-through;font-weight:400;margin-left:10px">₹${p.mrp.toLocaleString('en-IN')}</span>
        ${disc>0?`<span style="font-size:13px;color:#27ae60;font-weight:700;margin-left:8px">${disc}% off</span>`:''}
      </div>
      <div class="pd-desc">${p.desc}</div>
      <div class="pd-actions">
        <button class="btn-cart" onclick="addToCart(${p.id});closeModal('pd-modal')">Add to Cart</button>
        <button class="pd-wa" onclick="shareWA(${p.id})">💬 WhatsApp</button>
      </div>
    </div>`;
  openModal('pd-modal');
}

// ============================================================
// CART
// ============================================================
function addToCart(id) {
  const p = products.find(x=>x.id===id);
  if(!p) return;
  const ex = cart.find(i=>i.id===id);
  if(ex) ex.qty++;
  else cart.push({...p, qty:1});
  updateCartUI();
  showToast(`✓ "${p.name}" added to cart`, 'success');
}
function updateCartUI() {
  const count = cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('cart-count').textContent = count;
  renderCart();
}
function renderCart() {
  const body = document.getElementById('cart-body');
  const footer = document.getElementById('cart-footer');
  if(cart.length===0){
    body.innerHTML='<div class="cart-empty">🛒<br><br>Your cart is empty.</div>';
    footer.style.display='none'; return;
  }
  footer.style.display='block';
  let total=0;
  body.innerHTML = cart.map(item=>{
    total += item.price*item.qty;
    const img = item.img
      ? `<img src="${item.img}" style="width:100%;height:100%;object-fit:cover" onerror="this.outerHTML='<div style=\'display:flex;align-items:center;justify-content:center;font-size:38px;width:100%;height:100%\'>${item.emoji}</div>'">`
      : `<div class="ci-img-emoji">${item.emoji}</div>`;
    return `<div class="cart-item">
      <div class="ci-img">${img}</div>
      <div class="ci-info">
        <div class="ci-name">${item.name}</div>
        <div class="ci-price">₹${(item.price*item.qty).toLocaleString('en-IN')}</div>
        <div class="qty-row">
          <button class="qty-btn" onclick="chQty(${item.id},-1)">−</button>
          <span class="qty-n">${item.qty}</span>
          <button class="qty-btn" onclick="chQty(${item.id},1)">+</button>
        </div>
        <button class="ci-del" onclick="remCart(${item.id})">🗑 Remove</button>
      </div>
    </div>`;
  }).join('');
  document.getElementById('cart-total').textContent = `₹${total.toLocaleString('en-IN')}`;
}
function chQty(id,d){const i=cart.find(x=>x.id===id);if(!i)return;i.qty+=d;if(i.qty<=0)cart=cart.filter(x=>x.id!==id);updateCartUI();}
function remCart(id){cart=cart.filter(x=>x.id!==id);updateCartUI();}
function openCart(){document.getElementById('cart-sidebar').classList.add('open');document.getElementById('sidebar-ov').classList.add('active');renderCart();}
function closeCart(){document.getElementById('cart-sidebar').classList.remove('open');document.getElementById('sidebar-ov').classList.remove('active');}

function checkoutWhatsApp() {
  if(cart.length===0) return;
  const total = cart.reduce((s,i)=>s+i.price*i.qty,0);
  let msg = `🛍️ *My Order*\n\n*Items:*\n`;
  cart.forEach(i=>{
    msg += `• ${i.emoji} ${i.name} x${i.qty} — ₹${(i.price*i.qty).toLocaleString('en-IN')}\n`;
    if(i.img && i.img.trim()!=='' && !i.img.startsWith('data:')) msg += `  🖼️ ${i.img}\n`;
  });
  msg += `\n*Total: ₹${total.toLocaleString('en-IN')}*\n\nPlease confirm my order! 🙏`;
  window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
}

// ============================================================
// WHATSAPP SHARE
// ============================================================
function shareWA(id) {
  const p = products.find(x=>x.id===id);
  if(!p) return;
  let msg = `${p.emoji} *${p.name}*\n`;
  msg += `💰 Price: ₹${p.price.toLocaleString('en-IN')} (MRP ₹${p.mrp.toLocaleString('en-IN')})\n`;
  msg += `📝 ${p.desc}`;
  if(p.img && p.img.trim()!=='' && !p.img.startsWith('data:')) msg += `\n\n🖼️ ${p.img}`;
  window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
  showToast('💬 Opening WhatsApp...','wa');
}

// ============================================================
// MODALS
// ============================================================
function openModal(id){document.getElementById(id).classList.add('active');}
function closeModal(id){document.getElementById(id).classList.remove('active');}
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('active');}));

// ============================================================
// AUTH
// ============================================================
function googleLogin() {
  const name = prompt('Google Sign-In (simulation)\nEnter your name:');
  if(!name) return;
  currentUser={name,email:name.toLowerCase().replace(/ /g,'')+'@gmail.com',avatar:name[0].toUpperCase(),isAdmin:false};
  updateUserUI(); closeModal('login-modal');
  showToast(`✓ Welcome, ${name}!`,'success');
}
function doLogin() {
  const email = document.getElementById('login-email').value.trim().toLowerCase();
  const pass = document.getElementById('login-pass').value;
  if(!email){showToast('Please enter your email.');return;}
  if(!pass){showToast('Please enter your password.');return;}
  if(email===ADMIN_EMAIL && pass===ADMIN_PASSWORD){
    isAdmin=true;
    currentUser={name:'Admin',email,avatar:'⚙',isAdmin:true};
    updateUserUI(); closeModal('login-modal');
    document.getElementById('admin-link').style.display='inline';
    showToast('✓ Welcome, Admin!','success');
    setTimeout(()=>{
      document.getElementById('admin-login-form').style.display='none';
      document.getElementById('admin-panel').style.display='block';
      renderAdminProducts();
      openModal('admin-modal');
    },600);
    return;
  }
  const name = email.split('@')[0];
  currentUser={name,email,avatar:name[0].toUpperCase(),isAdmin:false};
  updateUserUI(); closeModal('login-modal');
  showToast(`✓ Welcome, ${name}!`,'success');
}
function updateUserUI() {
  const btn=document.getElementById('login-btn');
  if(currentUser){
    const ab=currentUser.isAdmin?' <span class="admin-badge">ADMIN</span>':'';
    btn.innerHTML=`<span class="uavatar">${currentUser.avatar}</span> ${currentUser.name.split(' ')[0]}${ab}`;
    btn.onclick=()=>{
      if(confirm(`Logged in as ${currentUser.name}.\nLogout?`)){
        currentUser=null;isAdmin=false;
        document.getElementById('admin-link').style.display='none';
        document.getElementById('admin-login-form').style.display='block';
        document.getElementById('admin-panel').style.display='none';
        updateUserUI(); showToast('Logged out.');
      }
    };
  } else {
    btn.innerHTML='👤 Login';
    btn.onclick=()=>openModal('login-modal');
  }
}

// ============================================================
// ADMIN
// ============================================================
function adminLogin() {
  const pass = document.getElementById('admin-pass').value;
  if(pass===ADMIN_PASSWORD){
    isAdmin=true;
    document.getElementById('admin-login-form').style.display='none';
    document.getElementById('admin-panel').style.display='block';
    document.getElementById('admin-link').style.display='inline';
    renderAdminProducts();
    showToast('✓ Admin access granted!','success');
  } else { showToast('❌ Incorrect password!'); }
}
function saveShopSettings() {
  const name=document.getElementById('admin-shop-name').value.trim();
  const address=document.getElementById('admin-shop-address').value.trim();
  if(!name||!address){showToast('Fill all fields.');return;}
  shopSettings={name,address};
  document.getElementById('shop-name-display').innerHTML=`${name.split(' ')[0]} <span>${name.split(' ').slice(1).join(' ')||''}</span>`;
  document.getElementById('shop-address-display').textContent='📍 '+address;
  document.getElementById('footer-address-display').innerHTML=address+'<br>📞 8799721618';
  document.getElementById('contact-address-display').textContent=address;
  document.title=name;
  showToast('✓ Shop settings saved!','success');
}

// Image upload handlers
function previewHeroImg(input) {
  const file=input.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=e=>{
    const prev=document.getElementById('hero-img-preview');
    prev.src=e.target.result; prev.style.display='block';
    prev._data=e.target.result;
  };
  reader.readAsDataURL(file);
}
function applyHeroImg() {
  const prev=document.getElementById('hero-img-preview');
  if(!prev._data){showToast('Please upload an image first.');return;}
  heroImages[0]=prev._data;
  document.getElementById('hero-bg').style.backgroundImage=`url('${prev._data}')`;
  document.getElementById('ht0').src=prev._data;
  showToast('✓ Hero image updated!','success');
}
function previewPromo(input, previewId, targetId) {
  const file=input.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=e=>{
    const prev=document.getElementById(previewId);
    prev.src=e.target.result; prev.style.display='block';
    document.getElementById(targetId).src=e.target.result;
  };
  reader.readAsDataURL(file);
}
function previewProdImg(input) {
  const file=input.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=e=>{
    const prev=document.getElementById('prod-img-preview');
    prev.src=e.target.result; prev.style.display='block';
    newProdImgData=e.target.result;
  };
  reader.readAsDataURL(file);
}

function addProduct() {
  const name=document.getElementById('new-prod-name').value.trim();
  const cat=document.getElementById('new-prod-cat').value;
  const price=parseInt(document.getElementById('new-prod-price').value);
  const mrp=parseInt(document.getElementById('new-prod-mrp').value)||price;
  const desc=document.getElementById('new-prod-desc').value.trim();
  const emoji=document.getElementById('new-prod-emoji').value.trim()||'👗';
  if(!name||!price){showToast('Please fill Name and Price.');return;}
  const newId=Math.max(...products.map(p=>p.id))+1;
  products.push({id:newId,name,category:cat,price,mrp,emoji,desc:desc||'Beautiful fashion item.',img:newProdImgData});
  newProdImgData='';
  renderAdminProducts();
  filterByCategory(currentCategory);
  ['new-prod-name','new-prod-price','new-prod-mrp','new-prod-desc'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('prod-img-preview').style.display='none';
  showToast(`✓ "${name}" added!`,'success');
}
function renderAdminProducts() {
  document.getElementById('admin-products-list').innerHTML=products.map(p=>`
    <div class="adm-row">
      <span>${p.emoji}</span>
      <span><strong>${p.name}</strong><br><small style="color:#999">${p.category} · ₹${p.price}</small></span>
      <button class="adm-del" onclick="delProduct(${p.id})">🗑 Delete</button>
    </div>`).join('');
}
function delProduct(id) {
  if(!confirm('Delete this product?')) return;
  products=products.filter(p=>p.id!==id);
  renderAdminProducts(); filterByCategory(currentCategory);
  showToast('🗑 Product deleted.');
}

// ============================================================
// TOAST
// ============================================================
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast show'+(type?' '+type:'');
  setTimeout(()=>t.className='toast',2800);
}

// ============================================================
// INIT
// ============================================================
renderProducts(products);
</script>
