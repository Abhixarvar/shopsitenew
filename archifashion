function setHero(idx) {
  currentHeroIdx = idx;
  document.getElementById('hero-bg').style.backgroundImage = `url('${heroImages[idx]}')`;
  document.querySelectorAll('.hero-thumb').forEach((t,i) => t.classList.toggle('active', i===idx));
